generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Record {
  id         Int      @id @default(autoincrement())
  artist     String
  album      String
  year       Int?
  genre      String?
  artworkUrl String?
  starRating Int      @default(3)
  cost       Float?
  notes      String?
  createdAt  DateTime @default(now())
  tracks     Track[]
}

model Track {
  id          String   @id @default(cuid())
  recordId    Int
  record      Record   @relation(fields: [recordId], references: [id], onDelete: Cascade)
  position    String
  title       String
  duration    String?
  isFavourite Boolean  @default(false)
  order       Int
}

model WatchedRelease {
  id          Int      @id @default(autoincrement())
  mbid        String   @unique
  artist      String
  album       String
  releaseDate String
  createdAt   DateTime @default(now())
}

model WishlistItem {
  id          Int      @id @default(autoincrement())
  artist      String
  album       String
  year        Int?
  genre       String?
  artworkUrl  String?
  starRating  Int      @default(3)
  targetPrice Float?
  notes       String?
  tracklist   String?
  createdAt   DateTime @default(now())
}
